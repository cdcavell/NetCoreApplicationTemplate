# Copy this file to .env for local Docker Compose overrides.
# Do not commit .env files containing local secrets or machine-specific values.

ASPNETCORE_ENVIRONMENT=Development
CONNECTIONSTRINGS_APPLICATIONDATABASE=Data Source=/app/data/application-dev.db

PROJECTTEMPLATE_FORWARDEDHEADERS_ENABLED=true
PROJECTTEMPLATE_FORWARDEDHEADERS_FORWARDLIMIT=1
PROJECTTEMPLATE_FORWARDEDHEADERS_REQUIREHEADERSYMMETRY=false

# Local Docker development only.
# Production deployments should configure explicit KnownProxies or KnownNetworks.
PROJECTTEMPLATE_FORWARDEDHEADERS_CLEARKNOWNNETWORKSANDPROXIES=true

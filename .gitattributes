###############################################################################
# .gitattributes
# .NET Core Application Template
#
# Goals:
# - Normalize text line endings consistently.
# - Keep repository text files stored with LF endings.
# - Preserve CRLF only where Windows command scripts require it.
# - Protect binary files from text normalization and noisy diffs.
###############################################################################

# Normalize all text files to LF.
# This keeps the repository and working tree consistent across Windows, Linux, and macOS.
* text=auto eol=lf


###############################################################################
# Windows command scripts
###############################################################################

*.bat  text eol=crlf
*.cmd  text eol=crlf


###############################################################################
# Shell / scripting files
###############################################################################

*.sh       text eol=lf
*.bash     text eol=lf
*.zsh      text eol=lf
*.ps1      text eol=lf
*.psm1     text eol=lf
*.psd1     text eol=lf


###############################################################################
# .NET / C# project files
###############################################################################

*.cs        text eol=lf diff=csharp
*.cshtml    text eol=lf
*.razor     text eol=lf
*.csproj    text eol=lf
*.vbproj    text eol=lf
*.fsproj    text eol=lf
*.sln       text eol=lf
*.slnx      text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.nuspec    text eol=lf
*.resx      text eol=lf
*.config    text eol=lf


###############################################################################
# Web assets
###############################################################################

*.html      text eol=lf
*.htm       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.sass      text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf


###############################################################################
# Configuration files
###############################################################################

*.json      text eol=lf
*.jsonc     text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.env       text eol=lf
*.example   text eol=lf
*.editorconfig text eol=lf


###############################################################################
# SQL / database scripts
###############################################################################

*.sql       text eol=lf


###############################################################################
# Documentation
###############################################################################

*.md        text eol=lf diff=markdown
*.txt       text eol=lf
*.rst       text eol=lf


###############################################################################
# Docker / container files
###############################################################################

Dockerfile      text eol=lf
*.dockerfile    text eol=lf
.dockerignore   text eol=lf


###############################################################################
# GitHub / CI files
###############################################################################

.github/**/*.yml   text eol=lf
.github/**/*.yaml  text eol=lf


###############################################################################
# Binary files
###############################################################################

# Images
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.svgz    binary

# Fonts
*.ttf     binary
*.otf     binary
*.woff    binary
*.woff2   binary
*.eot     binary

# Archives
*.zip     binary
*.7z      binary
*.rar     binary
*.tar     binary
*.gz      binary

# Documents
*.pdf     binary
*.doc     binary
*.docx    binary
*.xls     binary
*.xlsx    binary
*.ppt     binary
*.pptx    binary

# Database files
*.db       binary
*.sqlite   binary
*.sqlite3  binary
*.mdf      binary
*.ldf      binary
*.bak      binary

# Keys / certificates
*.pfx      binary
*.snk      binary

# Executables / compiled output
*.exe      binary
*.dll      binary
*.pdb      binary
*.so       binary
*.dylib    binary
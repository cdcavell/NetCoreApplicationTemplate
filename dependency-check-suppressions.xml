<?xml version="1.0" encoding="UTF-8"?>
<suppressions
    xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.4.xsd"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.4.xsd
        https://dependency-check.github.io/DependencyCheck/dependency-suppression.1.4.xsd">

    <!--
    Cross-ecosystem OpenTelemetry findings applying to Go or C++
    implementations rather than the .NET NuGet packages.
  -->

    <suppress until="2027-01-31Z">
        <notes>
            <![CDATA[
      Reviewed cross-ecosystem false positives for the .NET OTLP exporter.
    ]]>
        </notes>
        <packageUrl regex="true">^pkg:nuget/OpenTelemetry\.Exporter\.OpenTelemetryProtocol@1\.17\.0$</packageUrl>
        <vulnerabilityName regex="true">^CVE-2026-(39882|39883|41178|44967)$</vulnerabilityName>
    </suppress>

    <suppress until="2027-01-31Z">
        <notes>
            <![CDATA[
      Reviewed cross-ecosystem false positives for OpenTelemetry .NET hosting.
    ]]>
        </notes>
        <packageUrl regex="true">^pkg:nuget/OpenTelemetry\.Extensions\.Hosting@1\.17\.0$</packageUrl>
        <vulnerabilityName regex="true">^CVE-2026-(39882|39883|41178|44967)$</vulnerabilityName>
    </suppress>

    <suppress until="2027-01-31Z">
        <notes>
            <![CDATA[
      Reviewed cross-ecosystem false positives for ASP.NET Core instrumentation.
    ]]>
        </notes>
        <packageUrl regex="true">^pkg:nuget/OpenTelemetry\.Instrumentation\.AspNetCore@1\.16\.0$</packageUrl>
        <vulnerabilityName regex="true">^CVE-2026-(39882|39883|41178|44967)$</vulnerabilityName>
    </suppress>

    <suppress until="2027-01-31Z">
        <notes>
            <![CDATA[
      Reviewed cross-ecosystem false positives for HTTP instrumentation.
    ]]>
        </notes>
        <packageUrl regex="true">^pkg:nuget/OpenTelemetry\.Instrumentation\.Http@1\.16\.0$</packageUrl>
        <vulnerabilityName regex="true">^CVE-2026-(39882|39883|41178|44967)$</vulnerabilityName>
    </suppress>

    <!--
    CVE-2012-2055 applies to historical GitHub Enterprise behavior,
    not these NuGet packages.
  -->

    <suppress until="2027-01-31Z">
        <notes>
            <![CDATA[
      CVE-2012-2055 does not apply to the ASP.NET Core GitHub OAuth client.
    ]]>
        </notes>
        <packageUrl regex="true">^pkg:nuget/AspNet\.Security\.OAuth\.GitHub@10\.0\.0$</packageUrl>
        <vulnerabilityName>CVE-2012-2055</vulnerabilityName>
    </suppress>

    <suppress until="2027-01-31Z">
        <notes>
            <![CDATA[
      CVE-2012-2055 does not apply to Microsoft Source Link.
    ]]>
        </notes>
        <packageUrl regex="true">^pkg:nuget/Microsoft\.SourceLink\.GitHub@10\.0\.301$</packageUrl>
        <vulnerabilityName>CVE-2012-2055</vulnerabilityName>
    </suppress>

</suppressions>
